<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Regulação</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Roboto:wght@400;500&display=swap');
        
        body { font-family: 'Inter', system-ui, sans-serif; }
        
        .tab-active { 
            border-bottom: 4px solid #2563eb; 
            color: #2563eb; 
            font-weight: 600; 
        }
        
        .patient-card {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .patient-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        }
        
        .modal { animation: modalPop 0.3s ease; }
        
        @@keyframes modalPop {
            0% { transform: scale(0.95); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        
        .red-priority { animation: pulse 2s infinite; }
        
        @@keyframes pulse {
            0%, 100% { background-color: #fee2e2; }
            50% { background-color: #fecaca; }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- HEADER -->
    <header class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-x-3">
                    <div class="w-10 h-10 bg-blue-600 rounded-2xl flex items-center justify-center text-white text-3xl font-bold">R</div>
                    <div>
                        <h1 class="text-3xl font-bold tracking-tight text-blue-700">REGULAÇÃO</h1>
                        <p class="text-xs text-gray-500 -mt-1">Sistema de Controle de Pacientes</p>
                    </div>
                </div>

                <select id="unit-select" onchange="changeUnit(this.value)" class="px-6 py-2 border border-gray-300 rounded-2xl text-sm font-medium focus:outline-none focus:border-blue-500">
                    <option value="UBS II">UBS II</option>
                    <option value="PAULO MANETTA">PAULO MANETTA</option>
                    <option value="SAPATEIRO">SAPATEIRO</option>
                    <option value="CAMPESTRE">CAMPESTRE </option>
                    <option value="FILIPINHO">FILIPINHO </option>
                    <option value="LAGOA GRANDE">LAGOA GRANDE</option>
                </select>

                <div class="flex items-center gap-x-8 text-sm font-medium">
                    <button onclick="changeTab(0)" id="tab-0" class="tab px-5 py-3 tab-active flex items-center gap-x-2"><span class="text-xl">📋</span> Cadastro</button>
                    <button onclick="changeTab(1)" id="tab-1" class="tab px-5 py-3 flex items-center gap-x-2"><span class="text-xl">⏳</span> Pendências</button>
                    <button onclick="changeTab(2)" id="tab-2" class="tab px-5 py-3 flex items-center gap-x-2"><span class="text-xl">❌</span> Cadastro com Erro</button>
                    <button onclick="changeTab(3)" id="tab-3" class="tab px-5 py-3 flex items-center gap-x-2"><span class="text-xl">🔄</span> Fila de Espera</button>
                    <button onclick="changeTab(4)" id="tab-4" class="tab px-5 py-3 flex items-center gap-x-2"><span class="text-xl">📅</span> Agendados</button>
                </div>

                <div class="flex items-center gap-x-4">
                    <button onclick="exportAllCSV()" class="flex items-center gap-x-2 px-5 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-2xl transition">
                        <span>📊</span> Exportar Excel
                    </button>
                    <button onclick="clearAllData()" class="px-4 py-2 text-red-500 hover:text-red-700 text-sm font-medium transition">
                        Limpar dados
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-6 py-8">
        <div id="content" class="min-h-[calc(100vh-200px)]"></div>
    </div>

    <!-- MODAL -->
    <div id="modal" class="hidden fixed inset-0 bg-black/60 flex items-center justify-center z-[999]">
        <div class="modal bg-white w-full max-w-3xl mx-4 rounded-3xl shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b flex items-center justify-between bg-gray-50">
                <div class="flex items-center gap-x-4">
                    <div id="modal-priority" class="hidden px-5 py-1.5 bg-red-100 text-red-700 text-sm font-bold rounded-3xl flex items-center gap-x-2">
                        <span class="text-lg">🚨</span> PRIORIDADE
                    </div>
                    <h2 id="modal-nome" class="text-2xl font-semibold"></h2>
                </div>
                <div class="flex items-center gap-x-4">
                    <button onclick="printCurrentPatient()" class="flex items-center gap-x-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl text-sm font-medium transition">
                        🖨️ Imprimir Cadastro
                    </button>
                    <button onclick="closeModal()" class="w-10 h-10 flex items-center justify-center text-3xl text-gray-400 hover:text-gray-600 transition">×</button>
                </div>
            </div>

            <div class="p-8 max-h-[70vh] overflow-auto" id="modal-content"></div>
            <div id="modal-actions" class="px-8 py-6 border-t bg-gray-50 flex justify-end gap-x-3"></div>
        </div>
    </div>

    <script>
        // ====================== CONFIGURAÇÃO ======================
        let currentUnit = "UBS II";
        let patients = [];
        let currentPatientId = null;
        let currentTabIndex = 0;
        let buscaAgendados = "";

        const tabs = [
            { name: "Cadastro", icon: "📋" },
            { name: "Pendências", icon: "⏳" },
            { name: "Cadastro com Erro", icon: "❌" },
            { name: "Fila de Espera", icon: "🔄" },
            { name: "Agendados", icon: "📅" }
        ];

        function getStorageKey() { return `regulacao_patients_${currentUnit}`; }

        function loadData() {
            const saved = localStorage.getItem(getStorageKey());
            patients = saved ? JSON.parse(saved) : [];
        }

        function saveData() {
            localStorage.setItem(getStorageKey(), JSON.stringify(patients));
        }

        function changeUnit(nova) {
            if (nova === currentUnit) return;
            currentUnit = nova;
            loadData();
            renderCurrentTab();
        }

       function pacienteMatchBusca(p){

if(!buscaAgendados) return false;

const busca = buscaAgendados.toLowerCase();

const nome = (p.nome || "").toLowerCase();
const cpf = (p.cpf || "");

return nome.includes(busca) || cpf.includes(busca);

}


        // ====================== AUXILIARES ======================
        function getToday() { return new Date().toISOString().split('T')[0]; }

        function calcularIdade(dataNasc) {
            if (!dataNasc) return "";
            const birth = new Date(dataNasc);
            const today = new Date();
            let age = today.getFullYear() - birth.getFullYear();
            if (today.getMonth() < birth.getMonth() || (today.getMonth() === birth.getMonth() && today.getDate() < birth.getDate())) age--;
            return age + " anos";
        }

        function formatCPF(cpf) {
        if (!cpf) return "";
        cpf = cpf.replace(/\D/g, '');
        return cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, "$1.$2.$3-$4");
        }

        function formatCNS(cns) {
            cns = cns.replace(/\D/g, '');
            if (cns.length === 15) return cns.replace(/(\d{3})(\d{4})(\d{4})(\d{4})/, "$1 $2 $3 $4");
            return cns;
        }

        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        async function buscarEnderecoPorCEP(cep) {
            cep = cep.replace(/\D/g, '');
            if (cep.length !== 8) return "";
            try {
                const res = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
                const data = await res.json();
                if (!data.erro) return `${data.logradouro}, ${data.bairro} - ${data.localidade}/${data.uf}`;
            } catch (e) {}
            return "";
        }

        // ====================== MODAL ======================
        let currentModalPatient = null;

        function openModal(patient) {
            currentModalPatient = patient;
            document.getElementById("modal").classList.remove("hidden");
            document.getElementById("modal-nome").textContent = patient.nome;

            const prioEl = document.getElementById("modal-priority");
            patient.prioridade ? prioEl.classList.remove("hidden") : prioEl.classList.add("hidden");

            let html = `
                <div class="grid grid-cols-2 gap-8 text-sm">
                    <div><p class="text-gray-500 mb-1">Data do cadastro</p><p class="font-medium">${patient.data}</p></div>
                    <div><p class="text-gray-500 mb-1">Unidade</p><p class="font-medium">${patient.unidade}</p></div>
                    <div><p class="text-gray-500 mb-1">Especialidade</p><p class="font-medium">${patient.especialidade}</p></div>
                    <div><p class="text-gray-500 mb-1">Telefone</p><p class="font-medium">${patient.telefone}</p></div>
                    <div><p class="text-gray-500 mb-1">Nome</p><p class="font-medium">${patient.nome}</p></div>
                    <div><p class="text-gray-500 mb-1">Data de Nascimento</p><p class="font-medium">${patient.dataNascimento} (${patient.idade || calcularIdade(patient.dataNascimento)})</p></div>
                    <div><p class="text-gray-500 mb-1">CPF</p><p class="font-medium">${formatCPF(patient.cpf)}</p></div>
                    <div><p class="text-gray-500 mb-1">CNS (Cartão SUS)</p><p class="font-medium">${formatCNS(patient.cns)}</p></div>
                    <div><p class="text-gray-500 mb-1">Nome da Mãe</p><p class="font-medium">${patient.nomeMae}</p></div>
                    <div class="col-span-2"><p class="text-gray-500 mb-1">Endereço</p><p class="font-medium">${patient.endereco}</p></div>
                    <div><p class="text-gray-500 mb-1">Sexo</p><p class="font-medium">${patient.sexo}</p></div>
                    <div><p class="text-gray-500 mb-1">Peso / Altura</p><p class="font-medium">${patient.peso} kg • ${patient.altura} cm</p></div>
                </div>
                <div class="mt-10 border-t pt-8">
                    <h3 class="font-semibold text-lg mb-4 text-blue-700">INFORMAÇÕES MÉDICAS</h3>
                    <p><strong>Médico Responsável:</strong> ${patient.medico || "—"}</p>
                    <p class="mt-4"><strong>História Clínica:</strong><br>${patient.historiaClinica || "—"}</p>
                    <p class="mt-4"><strong>Observações:</strong><br>${patient.observacoes || "—"}</p>
                </div>
            `;
            document.getElementById("modal-content").innerHTML = html;
            renderModalActions(patient);
        }

        function renderModalActions(patient) {
    let actionsHTML = `
        <button onclick="closeModal()" 
            class="px-8 py-3 text-gray-500 hover:text-gray-700 font-medium transition">Fechar</button>
    `;

    if (patient.status === "pendente") {
        actionsHTML += `
            <button onclick="marcarComoErro()" 
                class="flex items-center gap-x-3 px-8 py-3 bg-red-600 hover:bg-red-700 text-white rounded-2xl font-medium transition">
                <span class="text-2xl">❌</span> Com Erro
            </button>
            <button onclick="agendarPaciente()" 
                class="flex items-center gap-x-3 px-8 py-3 bg-violet-600 hover:bg-violet-700 text-white rounded-2xl font-medium transition">
                <span class="text-2xl">📅</span> Agendar
            </button>
        `;
    }

    document.getElementById("modal-actions").innerHTML = actionsHTML;
}

        function closeModal() {
            document.getElementById("modal").classList.add("hidden");
            currentModalPatient = null;
        }

        function printCurrentPatient() {
            if (!currentModalPatient) return;
            const p = currentModalPatient;
            const win = window.open('', '_blank');
            let printHTML = `<html><head><title>Cadastro - ${p.nome}</title><style>body{font-family:Arial;margin:40px;line-height:1.6;}</style></head><body>
                <h1>REGULAÇÃO - CADASTRO DE PACIENTE</h1>
                <p><strong>Data:</strong> ${p.data}</p>
                <p><strong>Nome:</strong> ${p.nome}</p>
                <p><strong>CPF:</strong> ${formatCPF(p.cpf)}</p>
                <p><strong>CNS:</strong> ${formatCNS(p.cns)}</p>
                <p><strong>Telefone:</strong> ${p.telefone}</p>
                <p><strong>Endereço:</strong> ${p.endereco}</p>
                <p><strong>Unidade:</strong> ${p.unidade} | Especialidade: ${p.especialidade}</p>
                <p><strong>Médico:</strong> ${p.medico || "—"}</p>
                <p><strong>História Clínica:</strong><br>${p.historiaClinica || "—"}</p>
                <p><strong>Observações:</strong><br>${p.observacoes || "—"}</p>
            </body></html>`;
            win.document.write(printHTML);
            win.document.close();
            setTimeout(() => win.print(), 500);
        }

        // ====================== AÇÕES ======================
        function marcarComoErro() {
            const p = patients.find(x => x.id === currentModalPatient.id);
            if (p) { p.status = "erro"; saveData(); closeModal(); renderCurrentTab(); }
        }

        function agendarPaciente() {
            const p = patients.find(x => x.id === currentModalPatient.id);
            if (p) { p.status = "fila"; saveData(); closeModal(); renderCurrentTab(); }
        }

        function marcarAgendado(id) {
        const data = prompt("Digite a data do agendamento (AAAA-MM-DD):");

        if(!data) return;

        const p = patients.find(x => x.id === id);

        if(p){
        p.status = "agendado";
        p.dataAgendamento = data;
        p.avisado = false;

        saveData();
        renderCurrentTab();
    }

}

        // ====================== CADASTRO ======================
        function renderCadastro() {
            const today = getToday();
            const html = `
                <div class="max-w-3xl mx-auto bg-white rounded-3xl shadow-xl p-10">
                    <h2 class="text-4xl font-bold text-blue-700 mb-10 flex items-center gap-x-4">
                        Novo Cadastro 
                        <span onclick="togglePrioridade(this)" id="btn-prioridade" class="ml-auto cursor-pointer px-8 py-3 text-lg bg-white border-2 border-red-300 hover:border-red-500 text-red-600 rounded-3xl transition flex items-center gap-x-3">
                            <span class="text-2xl">🚨</span> PRIORIDADE
                        </span>
                    </h2>

                    <form id="cadastro-form" onsubmit="salvarCadastro(event)" class="space-y-10">
                        <div class="grid grid-cols-2 gap-8">
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Data do dia</label><input type="date" id="data" value="${today}" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Unidade</label><input type="text" id="unidade" value="${currentUnit}" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Especialidade</label><input type="text" id="especialidade" placeholder="Digite a especialidade" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Telefone</label><input type="tel" id="telefone" placeholder="(11) 99999-9999" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Nome completo</label><input type="text" id="nome" required placeholder="Nome do paciente" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Data de Nascimento</label><input type="date" id="dataNascimento" required onchange="updateIdade(this)" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">CPF</label><input type="text" id="cpf" maxlength="11" placeholder="00000000000" required class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">CNS (Cartão SUS)</label><input type="text" id="cns" maxlength="15" placeholder="000000000000000" required class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Nome da mãe</label><input type="text" id="nomeMae" required class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">CEP</label><input type="text" id="cep" maxlength="8" placeholder="00000000" oninput="buscarEnderecoAutomatico(this)" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-500 mb-2">Endereço completo (editável)</label>
                            <input type="text" id="endereco" placeholder="Rua, número, bairro, cidade..." class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500">
                        </div>

                        <div class="grid grid-cols-3 gap-8">
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Sexo</label>
                                <select id="sexo" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500">
                                    <option value="Masculino">Masculino</option>
                                    <option value="Feminino">Feminino</option>
                                    <option value="Outro">Outro</option>
                                </select>
                            </div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Peso (kg)</label><input type="number" id="peso" step="0.1" placeholder="75.5" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                            <div><label class="block text-sm font-medium text-gray-500 mb-2">Altura (cm)</label><input type="number" id="altura" placeholder="170" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500"></div>
                        </div>

                        <div class="pt-8 border-t">
                            <h3 class="text-2xl font-semibold text-blue-700 mb-6">Informações Médicas</h3>
                            <div class="mb-6">
                                <label class="block text-sm font-medium text-gray-500 mb-2">Nome do Médico Responsável</label>
                                <input type="text" id="medico" placeholder="Dr. João Silva" class="w-full px-5 py-4 border border-gray-200 rounded-2xl focus:outline-none focus:border-blue-500">
                            </div>
                            <div class="grid grid-cols-2 gap-8">
                                <div>
                                    <label class="block text-sm font-medium text-gray-500 mb-2">História Clínica</label>
                                    <textarea id="historiaClinica" rows="4" placeholder="Descreva os sintomas e histórico..." class="w-full px-5 py-4 border border-gray-200 rounded-3xl resize-none"></textarea>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-500 mb-2">Observações</label>
                                    <textarea id="observacoes" rows="4" placeholder="Observações adicionais..." class="w-full px-5 py-4 border border-gray-200 rounded-3xl resize-none"></textarea>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="w-full py-6 bg-blue-700 hover:bg-blue-800 text-white text-xl font-semibold rounded-3xl transition">💾 SALVAR CADASTRO</button>
                    </form>
                </div>
            `;
            document.getElementById("content").innerHTML = html;
        }

        function buscarEnderecoAutomatico(input) {
            const cep = input.value.replace(/\D/g, '');
            if (cep.length === 8) {
                buscarEnderecoPorCEP(cep).then(end => {
                    if (end) document.getElementById("endereco").value = end;
                });
            }
        }

        function togglePrioridade(btn) {
            btn.classList.toggle("bg-red-600");
            btn.classList.toggle("text-white");
            btn.classList.toggle("border-red-600");
        }

        function salvarCadastro(e) {
            e.preventDefault();
            const isPrioridade = document.getElementById("btn-prioridade").classList.contains("bg-red-600");

            const newPatient = {
                id: generateId(),
                data: document.getElementById("data").value,
                unidade: document.getElementById("unidade").value,
                especialidade: document.getElementById("especialidade").value,
                telefone: document.getElementById("telefone").value,
                nome: document.getElementById("nome").value,
                dataNascimento: document.getElementById("dataNascimento").value,
                cpf: document.getElementById("cpf").value,
                cns: document.getElementById("cns").value,
                nomeMae: document.getElementById("nomeMae").value,
                endereco: document.getElementById("endereco").value,
                sexo: document.getElementById("sexo").value,
                peso: document.getElementById("peso").value,
                altura: document.getElementById("altura").value,
                medico: document.getElementById("medico").value,
                historiaClinica: document.getElementById("historiaClinica").value,
                observacoes: document.getElementById("observacoes").value,
                prioridade: isPrioridade,
                status: "pendente",
                avisado: false,
                idade: calcularIdade(document.getElementById("dataNascimento").value)
            };

            patients.unshift(newPatient);
            saveData();
            alert("✅ Cadastro salvo com sucesso!");
            changeTab(1);
        }

        // ====================== RENDERIZAÇÃO DAS ABAS ======================
        // ====================== PENDÊNCIAS - MOSTRA TUDO JÁ ABERTO ======================
function renderPendencias() {
    let pendentes = patients.filter(p => p.status === "pendente");
    
    // Ordena: prioridade primeiro
    pendentes.sort((a, b) => {
        if (a.prioridade && !b.prioridade) return -1;
        if (!a.prioridade && b.prioridade) return 1;
        return a.nome.localeCompare(b.nome);
    });

    let html = `
        <div class="mb-8">
            <h2 class="text-4xl font-bold text-gray-800">Pendências (${pendentes.length})</h2>
            <p class="text-gray-500">Pacientes aguardando análise</p>
        </div>
    `;

    if (pendentes.length === 0) {
        html += `<div class="bg-white p-12 rounded-3xl text-center text-gray-400 text-xl">Nenhuma pendência no momento.</div>`;
    } else {
        html += `<div class="space-y-6">`;
        
        pendentes.forEach(p => {
            const priorityClass = p.prioridade ? "border-red-500 bg-red-50" : "border-gray-200";

            html += `
                <div class="bg-white border ${priorityClass} rounded-3xl p-8">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <p class="text-2xl font-semibold">${p.nome || 'Sem nome'}</p>
                            <p class="text-gray-500">${formatCPF(p.cpf || '')} • ${p.telefone || ''}</p>
                        </div>
                        ${p.prioridade ? `<span class="px-6 py-2 bg-red-600 text-white text-sm font-bold rounded-3xl">PRIORIDADE</span>` : ''}
                    </div>

                    <div class="grid grid-cols-2 gap-x-12 gap-y-6 text-sm">
                        <div><span class="text-gray-500">Data:</span> ${p.data || ''}</div>
                        <div><span class="text-gray-500">Unidade:</span> ${p.unidade || ''}</div>
                        <div><span class="text-gray-500">Especialidade:</span> ${p.especialidade || ''}</div>
                        <div><span class="text-gray-500">Telefone:</span> ${p.telefone || ''}</div>
                        <div><span class="text-gray-500">Data Nasc:</span> \( {p.dataNascimento || ''} ( \){p.idade || calcularIdade(p.dataNascimento) || ''})</div>
                        <div><span class="text-gray-500">CPF:</span> ${formatCPF(p.cpf || '')}</div>
                        <div><span class="text-gray-500">CNS:</span> ${formatCNS(p.cns || '')}</div>
                        <div><span class="text-gray-500">Nome da Mãe:</span> ${p.nomeMae || ''}</div>
                        <div class="col-span-2"><span class="text-gray-500">Endereço:</span> ${p.endereco || ''}</div>
                        <div><span class="text-gray-500">Sexo:</span> ${p.sexo || ''}</div>
                        <div><span class="text-gray-500">Peso / Altura:</span> ${p.peso || ''} kg • ${p.altura || ''} cm</div>
                    </div>

                    <div class="mt-8 pt-6 border-t">
                        <p class="text-gray-500 mb-2">Médico Responsável:</p>
                        <p class="font-medium">${p.medico || "Não informado"}</p>
                    </div>

                    <div class="mt-6">
                        <p class="text-gray-500 mb-2">História Clínica:</p>
                        <p class="bg-gray-50 p-5 rounded-2xl whitespace-pre-wrap">${p.historiaClinica || "—"}</p>
                    </div>

                    <div class="mt-6">
                        <p class="text-gray-500 mb-2">Observações:</p>
                        <p class="bg-gray-50 p-5 rounded-2xl whitespace-pre-wrap">${p.observacoes || "—"}</p>
                    </div>

                    <!-- BOTÕES NO FINAL -->
                    <div class="flex gap-4 mt-10">
                        <button onclick="marcarComoErro('${p.id}')" 
                            class="flex-1 py-4 bg-red-600 hover:bg-red-700 text-white font-medium rounded-2xl transition">
                            ❌ Marcar como Erro
                        </button>
                        <button onclick="agendarPaciente('${p.id}')" 
                            class="flex-1 py-4 bg-violet-600 hover:bg-violet-700 text-white font-medium rounded-2xl transition">
                            📅 Agendar
                        </button>
                    </div>
                </div>
            `;
        });
        
        html += `</div>`;
    }
    
    document.getElementById("content").innerHTML = html;
}

// ====================== AÇÕES DOS BOTÕES ======================
function marcarComoErro(id) {
    const p = patients.find(x => x.id === id);
    if (p) {
        p.status = "erro";
        saveData();
        renderCurrentTab();
    }
}

function marcarAvisado(id){

    const p = patients.find(x => x.id === id);

    if(p){
        p.avisado = true;
        saveData();
        renderCurrentTab();
    }

}

function agendarPaciente(id) {
    const p = patients.find(x => x.id === id);
    if (p) {
        p.status = "fila";
        saveData();
        renderCurrentTab();
    }
}

function closeModal() {
    document.getElementById("modal").classList.add("hidden");
    currentModalPatient = null;
}

// ====================== CADASTRO COM ERRO - FUNCIONAL ======================
function renderErros() {
    let erros = patients.filter(p => p.status === "erro");
    
    let html = `
        <div class="mb-8">
            <h2 class="text-4xl font-bold text-red-700">Cadastro com Erro (${erros.length})</h2>
            <p class="text-gray-500">Cadastros que precisam ser corrigidos</p>
        </div>
    `;

    if (erros.length === 0) {
        html += `<div class="bg-white p-12 rounded-3xl text-center text-gray-400 text-xl">Nenhum cadastro com erro no momento.</div>`;
    } else {
        html += `<div class="grid grid-cols-1 gap-6">`;
        
        erros.forEach(p => {
            html += `
                <div onclick="openModalFromList('${p.id}')" 
                    class="patient-card cursor-pointer bg-white border border-red-300 rounded-3xl p-8 hover:border-red-500 transition">
                    <div class="flex items-center gap-x-6">
                        <div class="w-16 h-16 bg-red-100 text-red-700 rounded-3xl flex items-center justify-center text-4xl font-bold">
                            ${p.nome ? p.nome[0].toUpperCase() : 'X'}
                        </div>
                        <div class="flex-1">
                            <p class="text-2xl font-semibold text-red-700">${p.nome || 'Sem nome'}</p>
                            <p class="text-gray-600">${formatCPF(p.cpf || '')}</p>
                            <p class="text-sm text-gray-500 mt-1">${p.unidade || ''} • ${p.especialidade || ''}</p>
                        </div>
                    </div>

                    <div class="mt-6 pt-6 border-t grid grid-cols-2 gap-6 text-sm">
                        <div><span class="text-gray-500">Telefone:</span> ${p.telefone || ''}</div>
                        <div><span class="text-gray-500">Data Nasc:</span> ${p.dataNascimento || ''}</div>
                    </div>

                    <!-- Botões de ação -->
                    <div class="flex gap-4 mt-8">
                        <button onclick="event.stopImmediatePropagation(); corrigirEEnviarFila('${p.id}')" 
                            class="flex-1 py-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-2xl transition">
                            🔄 Corrigir e Enviar para Fila
                        </button>
                        <button onclick="event.stopImmediatePropagation(); descartarPaciente('${p.id}')" 
                            class="flex-1 py-4 bg-red-600 hover:bg-red-700 text-white font-medium rounded-2xl transition">
                            🗑️ Descartar Cadastro
                        </button>
                    </div>
                </div>
            `;
        });
        
        html += `</div>`;
    }
    
    document.getElementById("content").innerHTML = html;
}

// ====================== AÇÕES PARA CADASTRO COM ERRO ======================
function corrigirEEnviarFila(id) {
    const p = patients.find(x => x.id === id);
    if (p) {
        p.status = "fila";
        saveData();
        renderCurrentTab();
        alert("✅ Enviado para Fila de Espera");
    }
}

function enviarParaFila(id){

    const p = patients.find(x => x.id === id);

    if(p){
        p.status = "fila";
        saveData();
        renderCurrentTab();
    }

}

function openModalFromList(id) {
editingPatientId = id;

const p = patients.find(x => x.id === id);

document.getElementById("nome").value = p.nome || "";
document.getElementById("cpf").value = p.cpf || "";
document.getElementById("telefone").value = p.telefone || "";
document.getElementById("especialidade").value = p.especialidade || "";

document.getElementById("modal").classList.remove("hidden");
}

function descartarPaciente(id) {
    if (confirm("Tem certeza que deseja descartar este cadastro permanentemente?")) {
        patients = patients.filter(x => x.id !== id);
        saveData();
        renderCurrentTab();
        alert("🗑️ Cadastro descartado");
    }
}
        function renderFila() {
    let fila = patients.filter(p => p.status === "fila");

    let html = `
        <div class="mb-8">
            <h2 class="text-4xl font-bold text-violet-700">
                Fila de Espera (${fila.length})
            </h2>
        </div>
    `;

    if (fila.length === 0) {
        html += `
            <div class="bg-white p-12 rounded-3xl text-center text-gray-400 text-xl">
                Fila vazia.
            </div>
        `;
    } else {
        html += `<div class="grid grid-cols-1 gap-4">`;

        fila.forEach(p => {
            html += `
                <div class="patient-card bg-white border border-violet-200 rounded-3xl p-6 flex justify-between items-center">

                    <div onclick="openModalFromList('${p.id}')" 
                         class="flex items-center gap-x-6 cursor-pointer">

                        <div class="text-3xl">🔄</div>

                        <div>
                            <p class="text-xl font-semibold">${p.nome}</p>
                            <p class="text-gray-500">${formatCPF(p.cpf)}</p>
                            <p class="text-sm text-gray-400">${p.especialidade || ""}</p>
                        </div>

                    </div>

                    <!-- BOTÃO AGENDADO -->
                    <button onclick="event.stopPropagation(); marcarAgendado('${p.id}')"
                        class="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-2xl transition">
                        📅 Agendado
                    </button>

                </div>
            `;
        });

        html += `</div>`;
    }

    document.getElementById("content").innerHTML = html;
}

 function renderAgendados(){

let agendados = patients.filter(p => p.status === "agendado");

// FILTRO DA BUSCA
let filtrados = agendados;

if(buscaAgendados && buscaAgendados.trim() !== ""){

const busca = buscaAgendados.toLowerCase().replace(/\D/g,"");

filtrados = agendados.filter(p => {

const nome = (p.nome || "").toLowerCase();

const cpf = (p.cpf || "").replace(/\D/g,"");

return nome.includes(buscaAgendados.toLowerCase()) || cpf.includes(busca);

});

}

// DIVIDIR EM LISTAS
let naoAvisados = filtrados.filter(p => !p.avisado);
let avisados = filtrados.filter(p => p.avisado);

// jogar quem bate na busca para o topo
naoAvisados = naoAvisados.sort((a,b)=> pacienteMatchBusca(b) - pacienteMatchBusca(a));
avisados = avisados.sort((a,b)=> pacienteMatchBusca(b) - pacienteMatchBusca(a));

let html = `
<div class="mb-10">
<input 
id="buscaInput"
type="text"
placeholder="🔎 Buscar por nome ou CPF..."
class="w-full px-6 py-4 border border-gray-300 rounded-2xl focus:outline-none focus:border-blue-500 text-lg"
>
</div>
`;


// ================= AVISAR =================

html += `
<div class="mb-12">

<div class="flex items-center gap-x-4 mb-6">
<div class="text-4xl">📢</div>
<h3 class="text-3xl font-bold text-red-600">
Avisar (${naoAvisados.length})
</h3>
</div>
`;

if(naoAvisados.length === 0){
html += `<p class="text-gray-400">Nenhum paciente encontrado.</p>`;
}

naoAvisados.forEach(p => {

html += `
<div class="${pacienteMatchBusca(p) ? "bg-yellow-100 border-yellow-400" : "bg-white border-red-200"} rounded-3xl p-6 flex justify-between items-center mb-4">

<div>
<p class="font-semibold text-lg">${p.nome}</p>
<p class="text-gray-500">${p.telefone}</p>
<p class="text-gray-500">${formatCPF(p.cpf)}</p>
<p class="text-gray-500">${p.dataAgendamento || ""}</p>
</div>

<div class="flex gap-3">

<button onclick="abrirWhatsApp('${p.id}')"
class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-2xl text-sm">
WhatsApp
</button>

<button onclick="marcarAvisado('${p.id}')"
class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-2xl text-sm">
Avisado
</button>

</div>

</div>
`;

});

html += `</div>`;


// ================= AVISADOS =================

html += `
<div>

<div class="flex items-center gap-x-4 mb-6">
<div class="text-4xl">✅</div>
<h3 class="text-3xl font-bold text-emerald-600">
Avisados (${avisados.length})
</h3>
</div>
`;

if(avisados.length === 0){
html += `<p class="text-gray-400">Nenhum paciente encontrado.</p>`;
}

avisados.forEach(p => {

html += `
<div class="bg-white border border-emerald-200 rounded-3xl p-6 mb-4 opacity-80">

<p class="font-semibold text-lg">${p.nome}</p>
<p class="text-gray-500">${p.telefone}</p>

</div>
`;

});

html += `</div>`;

document.getElementById("content").innerHTML = html;


// ================= ATIVAR BUSCA =================

const input = document.getElementById("buscaInput");

input.value = buscaAgendados;

input.addEventListener("input", function(){

buscaAgendados = this.value;

renderAgendados();

});

input.focus();

}

////////////////// whatsapp///////////////////////

function abrirWhatsApp(id){

    const p = patients.find(x => x.id === id);

    if(!p || !p.telefone){
        alert("Paciente não possui telefone cadastrado.");
        return;
    }

    const numero = p.telefone.replace(/\D/g,'');

   const mensagem = `Bom dia, ${p.nome}! Aqui é da UBS II. 🏥

Informamos que sua consulta/exame de ${p.especialidade || "especialidade"} foi agendada para o dia: *${p.dataAgendamento || "DATA NÃO INFORMADA"}*.

📌 IMPORTANTE:
Você deve comparecer à unidade antes dessa data para trazer sua guia médica e retirar sua felipeta.

❌ CANCELAMENTO:
Se não puder ir, avise-nos o quanto antes para liberarmos a vaga.

🕒 Horário de atendimento: 7h às 15h.

⚠️ ATENÇÃO:
Responda com *OK* para confirmar o recebimento.`;

    const url = `https://wa.me/55${numero}?text=${encodeURIComponent(mensagem)}`;

    window.open(url, "_blank");

    // marcar como avisado
    p.avisado = true;
    saveData();
    renderCurrentTab();
}

        function renderCurrentTab() {
            for (let i = 0; i < 5; i++) {
                const tab = document.getElementById("tab-" + i);
                if (tab) tab.classList.remove("tab-active");
            }
            document.getElementById("tab-" + currentTabIndex).classList.add("tab-active");

            if (currentTabIndex === 0) renderCadastro();
            else if (currentTabIndex === 1) renderPendencias();
            else if (currentTabIndex === 2) renderErros();
            else if (currentTabIndex === 3) renderFila();
            else if (currentTabIndex === 4) renderAgendados();
        }

        function changeTab(index) {
            currentTabIndex = index;
            renderCurrentTab();
        }

        function init() {
            loadData();
            currentTabIndex = 0;
            renderCurrentTab();
            document.getElementById("unit-select").value = currentUnit;
        }

        window.onload = init;
    </script>
</body>
</html>